{
  "name": "houston-code",
  "displayName": "Houston",
  "description": "Mission control for your codebase — interactive flow visualization powered by architecture.md",
  "version": "0.0.1",
  "license": "MIT",
  "publisher": "houston",
  "repository": {
    "type": "git",
    "url": "https://github.com/canokay/houston"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization"
  ],
  "activationEvents": [
    "workspaceContains:architecture.md",
    "workspaceContains:.houston/architecture.md"
  ],
  "main": "./dist/extension/index.js",
  "contributes": {
    "commands": [
      {
        "command": "houston.open",
        "title": "Houston: Open Mission Control"
      },
      {
        "command": "houston.refresh",
        "title": "Houston: Refresh"
      }
    ],
    "keybindings": [
      {
        "command": "houston.open",
        "key": "ctrl+shift+h",
        "mac": "cmd+shift+h"
      }
    ]
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}

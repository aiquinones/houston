{
  "name": "houston-code",
  "displayName": "Houston",
  "description": "Mission control for your codebase — interactive flow visualization powered by architecture.md",
  "version": "0.0.1",
  "license": "MIT",
  "publisher": "houston",
  "repository": {
    "type": "git",
    "url": "https://github.com/canokay/houston"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization"
  ],
  "activationEvents": [
    "workspaceContains:architecture.md",
    "workspaceContains:.houston/architecture.md"
  ],
  "type": "module",
  "main": "./dist/extension/index.cjs",
  "contributes": {
    "commands": [
      {
        "command": "houston.open",
        "title": "Houston: Open Mission Control"
      },
      {
        "command": "houston.refresh",
        "title": "Houston: Refresh"
      }
    ],
    "keybindings": [
      {
        "command": "houston.open",
        "key": "ctrl+shift+h",
        "mac": "cmd+shift+h"
      }
    ]
  },
  "scripts": {
    "dev": "node scripts/build.mjs --watch",
    "build": "node scripts/build.mjs",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "package": "pnpm build && npx @vscode/vsce package --no-dependencies"
  },
  "dependencies": {
    "remark-frontmatter": "^5.0.0",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.0",
    "yaml": "^2.4.0"
  },
  "devDependencies": {
    "@types/mdast": "^4.0.4",
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/vscode": "^1.85.0",
    "@xyflow/react": "^12.0.0",
    "esbuild": "^0.21.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.4.0"
  }
}
